      <aliases enabled='yes' />
      <column caption='Profit Ratio' datatype='real' name='[Calculation_1368249927221915648]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='SUM([Profit])/SUM([Sales])' />
      </column>
      <column caption='Profit Determination' datatype='string' name='[Calculation_2252403872174082]' role='measure' type='nominal'>
        <calculation class='tableau' formula='IF SUM([Profit]) &gt; 0&#10;THEN &quot;positive&quot;&#10;ElSE &quot;negative&quot;&#10;END' />
      </column>
      <column caption='Cost' datatype='real' name='[Calculation_2252403873239043]' role='measure' type='ordinal'>
        <calculation class='tableau' formula='SUM([Sales]) - SUM([Profit])' />
      </column>
      <column caption='Average Cost' datatype='real' name='[Calculation_2252403875995652]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='[Calculation_2252403873239043]/SUM([Quantity])' />
      </column>
      <column caption='Profit/Sales' datatype='real' name='[Calculation_2252403876597765]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='SUM([Profit])/SUM([Sales])' />
      </column>
      <column caption='Manufacturer Comparison' datatype='string' name='[Calculation_2252404152737798]' role='measure' type='nominal'>
        <calculation class='tableau' formula='IF SUM([Profit]) / SUM([Sales]) &gt; -0.1&#10;THEN &quot;Fair Supplier Choice&quot;&#10;ELSE &quot;Poor Supplier Choice&quot;&#10;END' />
      </column>
      <column caption='Time Between Date' datatype='integer' name='[Calculation_2252404154302471]' role='measure' type='quantitative'>
        <calculation class='tableau' formula='DATEDIFF(&quot;day&quot;, [Order Date], [Ship Date])' />
      </column>
